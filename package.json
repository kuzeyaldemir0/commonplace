{
  "name": "commonplace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web -c green,blue \"node --import tsx server/index.ts\" \"vite\"",
    "build": "tsc --noEmit && vite build",
    "start": "node --import tsx server/index.ts",
    "test": "vitest run",
    "cli": "node --import tsx server/cli.ts",
    "validate": "node --import tsx server/cli.ts validate"
  },
  "dependencies": {
    "express": "^5.1.0",
    "katex": "^0.16.22",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.3",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vitest": "^3.1.2"
  }
}
